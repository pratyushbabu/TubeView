NODE_ENV=development
PORT=8000
CORS_ORIGIN=http://localhost:3000

# Use either MONGODB_URI or MONGODB_URL.
MONGODB_URI=mongodb://127.0.0.1:27017/YouTubeDuplicateDB

ACCESS_TOKEN_SECRET=replace_with_a_long_random_access_secret
ACCESS_TOKEN_EXPIRY=1d

REFRESH_TOKEN_SECRET=replace_with_a_long_random_refresh_secret
REFRESH_TOKEN_EXPIRY=10d

CLOUDINARY_CLOUD_NAME=replace_with_cloud_name
CLOUDINARY_API_KEY=replace_with_api_key
CLOUDINARY_API_SECRET=replace_with_api_secret
